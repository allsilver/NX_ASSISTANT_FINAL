<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>NxAssistant</AssemblyName>
    <RootNamespace>NxAssistant</RootNamespace>
    <ApplicationIcon>assets\nx_assistant.ico</ApplicationIcon>

    <WebView2CoreDll>$(WEBVIEW2_CORE_DLL)</WebView2CoreDll>
    <WebView2WinFormsDll>$(WEBVIEW2_WINFORMS_DLL)</WebView2WinFormsDll>
    <WebView2LoaderDll>$(WEBVIEW2_LOADER_DLL)</WebView2LoaderDll>

    <!-- WEBVIEW2_CORE_DLL 경로에 dll 이 실제로 있으면 VDI(로컬 dll 참조),
         없으면(환경변수가 비었거나 그 경로에 파일이 없으면) 로컬 PC NuGet 복원. -->
    <UseWebView2Nuget Condition="!Exists('$(WEBVIEW2_CORE_DLL)')">true</UseWebView2Nuget>
  </PropertyGroup>

  <!-- VDI 전용: 환경변수 누락 시 빌드 에러. NuGet 모드면 검사 스킵 -->
  <Target Name="CheckWebView2Env" BeforeTargets="Build" Condition="'$(UseWebView2Nuget)' != 'true'">
    <Error Condition="'$(WebView2CoreDll)' == ''"
           Text="환경변수 WEBVIEW2_CORE_DLL 이 설정되지 않았습니다." />
    <Error Condition="'$(WebView2WinFormsDll)' == ''"
           Text="환경변수 WEBVIEW2_WINFORMS_DLL 이 설정되지 않았습니다." />
    <Error Condition="'$(WebView2LoaderDll)' == ''"
           Text="환경변수 WEBVIEW2_LOADER_DLL 이 설정되지 않았습니다." />
  </Target>

  <!-- VDI: 로컬 dll 직접 참조 -->
  <ItemGroup Condition="'$(UseWebView2Nuget)' != 'true'">
    <Reference Include="Microsoft.Web.WebView2.Core">
      <HintPath>$(WebView2CoreDll)</HintPath>
    </Reference>
    <Reference Include="Microsoft.Web.WebView2.WinForms">
      <HintPath>$(WebView2WinFormsDll)</HintPath>
    </Reference>
    <None Include="$(WebView2LoaderDll)">
      <Link>WebView2Loader.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- 로컬 PC: NuGet 패키지 (Core/WinForms/Loader 모두 포함) -->
  <ItemGroup Condition="'$(UseWebView2Nuget)' == 'true'">
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2592.51" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="ui\assets\gauss_logo.png" />
    <EmbeddedResource Include="ui\assets\chatgpt_logo.png" />
  </ItemGroup>
  <ItemGroup>
    <None Update="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    <None Update="appsettings.local.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <!-- 흡수된 NX 브리지 / 자동화 툴을 exe 옆으로 복사 → appsettings의 상대경로(nx-mcp/automation)가 해석됨 -->
  <ItemGroup>
    <None Include="..\nx-mcp\**\*" Link="nx-mcp\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\automation\**\*" Link="automation\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
